# Sandbox image shipping real coding agents (Codex, Cursor CLI, Claude Code) so
# they run headless inside a governed sandbox. Drive it with the *-agent.toml
# example profiles. Runs as non-root user `agent` owning /workspace.
FROM debian:stable-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git curl ca-certificates python3 nodejs npm \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @openai/codex @anthropic-ai/claude-code

RUN useradd -m -u 1000 agent \
    && mkdir -p /workspace \
    && chown -R agent:agent /workspace

USER agent
ENV HOME=/home/agent

# Cursor CLI installs into the user's home (~/.local/bin or ~/.cursor/bin).
RUN curl https://cursor.com/install -fsS | bash
ENV PATH="/home/agent/.local/bin:/home/agent/.cursor/bin:${PATH}"

WORKDIR /workspace
CMD ["sleep", "infinity"]
