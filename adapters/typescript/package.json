{
  "name": "@runeward/sdk",
  "version": "0.1.0",
  "description": "TypeScript client and Vercel AI SDK tools for the runeward governed execution cell.",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/adefemi171/runeward"
  },
  "keywords": [
    "ai",
    "agents",
    "sandbox",
    "mcp",
    "governance",
    "vercel-ai-sdk"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./ai-tools": {
      "types": "./dist/ai-tools.d.ts",
      "import": "./dist/ai-tools.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "ai": ">=3.0.0",
    "zod": ">=3.22.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
